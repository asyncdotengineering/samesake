{
  "name": "samesake-matcher-app",
  "version": "1.0.0",
  "description": "Standalone runner for the samesake matcher. Wires Gemini into createMatcher and calls Bun.serve().",
  "type": "module",
  "private": true,
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@samesake/core": "workspace:*",
    "@samesake/providers": "workspace:*",
    "@samesake/server": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.19",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  }
}
