# Postgres + pgvector connection string for samesake
DATABASE_URL=postgresql://user:pass@localhost:5432/samesake
# samesake project API key (any string ≥ 8 chars)
API_KEY=dev-key-please-change
# Gemini: powers gemini-embedding-2 (embeddings) and gemini-3.1-flash-lite (NLQ)
GEMINI_API_KEY=
# OpenAI: powers the Mastra agent (gpt-4.1-mini)
OPENAI_API_KEY=
