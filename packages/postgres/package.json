{
  "name": "@samesake/postgres",
  "version": "6.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncdotengineering/samesake"
  },
  "description": "PostgreSQL reference backend for samesake: retrieval, enrichment state, resolution candidates, vocabulary, facets, and the Tier-2 bundle.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "samesake",
    "postgres",
    "search",
    "pgvector",
    "facets"
  ],
  "peerDependencies": {
    "postgres": "^3.4.0"
  },
  "dependencies": {
    "@samesake/core": "workspace:^",
    "@samesake/embed": "workspace:^",
    "@samesake/enrich": "workspace:^",
    "@samesake/query": "workspace:^"
  },
  "devDependencies": {
    "postgres": "^3.4.9",
    "tsup": "^8.5.1"
  }
}
