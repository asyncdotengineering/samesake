{
  "name": "@samesake/mcp",
  "version": "6.0.0",
  "description": "Stdio MCP server that exposes a deployed samesake matcher (hybrid search + agent-commerce tools) to any MCP client.",
  "type": "module",
  "bin": {
    "samesake-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --experimental-strip-types src/index.ts"
  },
  "keywords": [
    "samesake",
    "mcp",
    "model-context-protocol",
    "search",
    "agent-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
